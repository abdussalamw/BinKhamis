// app/Jobs/CheckAbsentStudents.php

public function handle(): void

{

    $absentStudents = Enrollment::with(['student.parent'])

        ->whereHas('attendance', function($q) {

            $q->where('status', 'absent')

              ->where('date', '>=', now()->subDays(3));

        })

        ->get()

        ->filter(fn($e) => $e->attendance->where('status', 'absent')->count() >= 3);

    

    foreach ($absentStudents as $enrollment) {

        $enrollment->student->notify(new StudentAbsentAlert($enrollment));

        if ($enrollment->student->profile->parent_id) {

            $enrollment->student->profile->parent->notify(

                new ParentAbsentAlert($enrollment->student, $enrollment->circle)

            );

        }

    }

}



