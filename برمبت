📐 مخطط الجداول الأساسي:

1️⃣ جدول users (المستخدمون - جميع الأدوار)



CREATE TABLE users (

    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    name VARCHAR(100) NOT NULL,

    email VARCHAR(255) UNIQUE NULL,

    phone VARCHAR(20) UNIQUE NOT NULL,

    password VARCHAR(255) NOT NULL,

    role VARCHAR(30) CHECK (role IN ('super_admin','admin','teacher','student','parent')),

    avatar VARCHAR(255) NULL,

    is_active BOOLEAN DEFAULT TRUE,

    last_login_at TIMESTAMP NULL,

    email_verified_at TIMESTAMP NULL,

    remember_token VARCHAR(100) NULL,

    created_at TIMESTAMP DEFAULT NOW(),

    updated_at TIMESTAMP DEFAULT NOW(),

    deleted_at TIMESTAMP NULL

);



CREATE INDEX idx_users_phone ON users(phone);

CREATE INDEX idx_users_role ON users(role) WHERE is_active = TRUE;



2️⃣ جدول profiles (البيانات التفصيلية حسب الدور)

CREATE TABLE profiles (

    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    user_id UUID UNIQUE NOT NULL REFERENCES users(id) ON DELETE CASCADE,

    type VARCHAR(20) CHECK (type IN ('student','teacher','parent')),

    

    -- حقول مشتركة

    birth_date DATE NULL,

    gender VARCHAR(1) CHECK (gender IN ('M','F')) NULL,

    address TEXT NULL,

    

    -- حقول خاصة بالطالب

    current_level VARCHAR(50) NULL, -- 'juz_30', 'juz_29-30', 'full_quran'

    memorization_method VARCHAR(30) NULL, -- 'oral', 'written', 'mixed'

    parent_id UUID NULL REFERENCES users(id),

    

    -- حقول خاصة بالمعلم

    specialization VARCHAR(100) NULL,

    hire_date DATE NULL,

    bio TEXT NULL,

    

    -- حقول خاصة بولي الأمر

    relation VARCHAR(20) CHECK (relation IN ('father','mother','guardian')) NULL,

    emergency_contact VARCHAR(20) NULL,

    

    -- بيانات مرنة إضافية

    metadata JSONB DEFAULT '{}'::jsonb,

    

    created_at TIMESTAMP DEFAULT NOW(),

    updated_at TIMESTAMP DEFAULT NOW()

);



CREATE INDEX idx_profiles_user ON profiles(user_id);

CREATE INDEX idx_profiles_parent ON profiles(parent_id) WHERE parent_id IS NOT NULL;

3️⃣ جدول circles (الحلقات)

CREATE TABLE circles (

    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    name VARCHAR(100) NOT NULL,

    description TEXT NULL,

    location VARCHAR(255) NOT NULL,

    location_coords POINT NULL, -- للتكامل مع الخرائط مستقبلاً

    schedule JSONB NOT NULL, -- {days: ['sun','tue'], time_start: '17:00', time_end: '18:30'}

    capacity INTEGER CHECK (capacity > 0),

    teacher_id UUID NOT NULL REFERENCES users(id),

    is_active BOOLEAN DEFAULT TRUE,

    created_at TIMESTAMP DEFAULT NOW(),

    updated_at TIMESTAMP DEFAULT NOW(),

    deleted_at TIMESTAMP NULL

);



CREATE INDEX idx_circles_teacher ON circles(teacher_id) WHERE is_active = TRUE;

CREATE INDEX idx_circles_location ON circles USING GIST (location_coords) WHERE location_coords IS NOT NULL;



4️⃣ جدول enrollments (تسجيل الطلاب في الحلقات)CREATE TABLE enrollments (

    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    student_id UUID NOT NULL REFERENCES users(id),

    circle_id UUID NOT NULL REFERENCES circles(id),

    enrolled_at TIMESTAMP DEFAULT NOW(),

    status VARCHAR(20) CHECK (status IN ('active','paused','completed','dropped')) DEFAULT 'active',

    notes TEXT NULL,

    created_at TIMESTAMP DEFAULT NOW(),

    updated_at TIMESTAMP DEFAULT NOW(),

    

    UNIQUE(student_id, circle_id) WHERE status IN ('active','paused')

);



CREATE INDEX idx_enrollments_student ON enrollments(student_id);

CREATE INDEX idx_enrollments_circle ON enrollments(circle_id);

5️⃣ جدول attendance (سجل الحضور اليومي)

CREATE TABLE attendance (

    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    enrollment_id UUID NOT NULL REFERENCES enrollments(id),

    date DATE NOT NULL,

    status VARCHAR(20) CHECK (status IN ('present','absent','late','excused')) NOT NULL,

    teacher_note TEXT NULL,

    recorded_by UUID NOT NULL REFERENCES users(id),

    created_at TIMESTAMP DEFAULT NOW(),

    

    UNIQUE(enrollment_id, date)

);



CREATE INDEX idx_attendance_date ON attendance(date);

CREATE INDEX idx_attendance_enrollment ON attendance(enrollment_id);

CREATE INDEX idx_attendance_status ON attendance(status) WHERE status = 'absent';

6️⃣ جدول progress_tracking (تتبع التقدم في الحفظ)CREATE TABLE progress_tracking (

    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    student_id UUID NOT NULL REFERENCES users(id),

    surah_name VARCHAR(100) NOT NULL, -- اسم السورة بالعربية

    surah_number INTEGER CHECK (surah_number BETWEEN 1 AND 114),

    start_verse INTEGER CHECK (start_verse >= 1),

    end_verse INTEGER CHECK (end_verse >= start_verse),

    completion_date DATE NULL,

    quality_rating VARCHAR(20) CHECK (quality_rating IN ('excellent','good','needs_review')),

    teacher_id UUID NOT NULL REFERENCES users(id),

    notes TEXT NULL,

    audio_recording_url VARCHAR(255) NULL, -- رابط تسجيل التلاوة (مستقبلي)

    created_at TIMESTAMP DEFAULT NOW(),

    updated_at TIMESTAMP DEFAULT NOW()

);



CREATE INDEX idx_progress_student ON progress_tracking(student_id);

CREATE INDEX idx_progress_surah ON progress_tracking(surah_name);

CREATE INDEX idx_progress_date ON progress_tracking(completion_date) WHERE completion_date IS NOT NULL;



-- تفعيل البحث النصي للعربية

CREATE INDEX idx_progress_surah_trgm ON progress_tracking USING gin (surah_name gin_trgm_ops);

7️⃣ جدول notifications (نظام الإشعارات)

CREATE TABLE notifications (

    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    user_id UUID NOT NULL REFERENCES users(id),

    type VARCHAR(50) CHECK (type IN ('absence_alert','review_reminder','event_announcement','system','message')),

    title VARCHAR(255) NOT NULL,

    body TEXT NOT NULL,

    data JSONB NULL, -- {circle_id, date, action_url, ...}

    is_read BOOLEAN DEFAULT FALSE,

    read_at TIMESTAMP NULL,

    created_at TIMESTAMP DEFAULT NOW(),

    expires_at TIMESTAMP NULL

);



CREATE INDEX idx_notifications_user ON notifications(user_id, is_read);

CREATE INDEX idx_notifications_unread ON notifications(user_id) WHERE is_read = FALSE AND expires_at > NOW();

8️⃣ جدول activity_logs (سجل التدقيق والأمان)

CREATE TABLE activity_logs (

    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    user_id UUID NULL REFERENCES users(id),

    action VARCHAR(100) NOT NULL, -- 'login', 'import_data', 'update_progress', ...

    target_type VARCHAR(50) NULL, -- 'User', 'Circle', 'Attendance'

    target_id UUID NULL,

    old_values JSONB NULL,

    new_values JSONB NULL,

    ip_address INET NULL,

    user_agent TEXT NULL,

    created_at TIMESTAMP DEFAULT NOW()

);



CREATE INDEX idx_activity_logs_user ON activity_logs(user_id);

CREATE INDEX idx_activity_logs_action ON activity_logs(action);

CREATE INDEX idx_activity_logs_date ON activity_logs(created_at);

🔧 Views للتقارير السريعة:

-- عرض ملخص الطالب

CREATE VIEW view_student_summary AS

SELECT 

    u.id, u.name, u.phone, p.birth_date, p.current_level,

    COUNT(DISTINCT e.circle_id) as active_circles,

    COUNT(DISTINCT CASE WHEN a.status = 'present' THEN a.id END) as total_present,

    COUNT(DISTINCT CASE WHEN a.status = 'absent' THEN a.id END) as total_absent,

    MAX(pt.updated_at) as last_progress_update

FROM users u

LEFT JOIN profiles p ON p.user_id = u.id

LEFT JOIN enrollments e ON e.student_id = u.id AND e.status = 'active'

LEFT JOIN attendance a ON a.enrollment_id = e.id

LEFT JOIN progress_tracking pt ON pt.student_id = u.id

WHERE u.role = 'student' AND u.is_active = TRUE

GROUP BY u.id, u.name, u.phone, p.birth_date, p.current_level;



-- عرض إحصائيات الحلقة

CREATE VIEW view_circle_stats AS

SELECT 

    c.id, c.name, c.capacity,

    COUNT(DISTINCT e.student_id) as enrolled_students,

    ROUND(AVG(CASE WHEN a.status = 'present' THEN 100.0 ELSE 0 END), 2) as attendance_rate,

    COUNT(DISTINCT pt.id) as total_progress_records,

    MAX(pt.updated_at) as last_activity

FROM circles c

LEFT JOIN enrollments e ON e.circle_id = c.id AND e.status = 'active'

LEFT JOIN attendance a ON a.enrollment_id = e.id

LEFT JOIN progress_tracking pt ON pt.student_id = e.student_id

WHERE c.is_active = TRUE

GROUP BY c.id, c.name, c.capacity;



