    // مستخدم مسؤول افتراضي

    $admin = User::firstOrCreate(

        ['phone' => '0500000000'],

        [

            'name' => 'مدير النظام',

            'password' => bcrypt(env('DEFAULT_ADMIN_PASSWORD', 'Admin@123')),

            'role' => 'super_admin',

            'email_verified_at' => now()

        ]

    );

    $admin->assignRole('super_admin');



    // 5 حلقات تجريبية

    $circles = Circle::factory(5)->create([

        'teacher_id' => fn() => User::factory()->teacher()->create()->id

    ]);



    // 20 طالباً مسجلين عشوائياً

    User::factory(20)->student()->create()->each(function($student) use ($circles) {

        $circle = $circles->random();

        Enrollment::create([

            'student_id' => $student->id,

            'circle_id' => $circle->id,

            'status' => 'active'

        ]);

        

        // سجل حضور عشوائي لآخر 30 يوم

        for ($i = 0; $i < 30; $i++) {

            Attendance::create([

                'enrollment_id' => Enrollment::where('student_id', $student->id)->first()->id,

                'date' => now()->subDays($i),

                'status' => ['present','present','present','absent','late'][array_rand([0,1,2,3,4])],

                'recorded_by' => $circle->teacher_id

            ]);

        }

    });

}



























